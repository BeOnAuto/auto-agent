{
  "name": "@auto-engineer/agent-cli",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "auto-agent": "./dist/bin/agent.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/bin/agent.js",
    "test": "vitest run --reporter=dot",
    "type-check": "tsc --noEmit",
    "link:dev": "pnpm build && pnpm link --global",
    "unlink:dev": "pnpm unlink --global",
    "release": "pnpm publish --no-git-checks"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "version": "0.1.0"
}
