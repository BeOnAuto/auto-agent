{
  "name": "@auto-engineer/server-generator-nestjs",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "generate:server": "tsx src/cli/index.ts",
    "-DISABLE-build": "tsc && tsx ../../scripts/fix-esm-imports.ts && rm -rf dist/src/codegen/templates && mkdir -p dist/src/codegen && cp -r src/codegen/templates dist/src/codegen/templates && cp -r src/shared dist/src",
    "-DISABLE-test": "vitest run --reporter=dot",
    "-DISABLE-type-check": "tsc --noEmit --project tsconfig.json",
    "-DISABLE-lint": "eslint 'src/**/*.ts' --ignore-pattern '**/*.specs.ts' --ignore-pattern '**/.tmp/**' --ignore-pattern 'src/shared/**' --max-warnings 0 --config ../../eslint.config.ts",
    "-DISABLE-format": "prettier --write \"**/*.{js,ts,json,md,yml,yaml}\" --ignore-path ../../.prettierignore --log-level warn",
    "-DISABLE-lint:fix": "eslint 'src/**/*.ts' --ignore-pattern '**/*.specs.ts' --ignore-pattern '**/.tmp/**' --fix --config ../../eslint.config.ts",
    "-DISABLE-format:fix": "prettier --write \"**/*.{js,ts,json,md,yml,yaml}\" --ignore-path ../../.prettierignore --log-level warn",
    "-DISABLE-link:dev": "pnpm build && pnpm link --global",
    "-DISABLE-unlink:dev": "pnpm unlink --global",
    "-DISABLE-prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@auto-engineer/narrative": "workspace:*",
    "@apollo/server": "^5.0.0",
    "@mikro-orm/cli": "^6.5.9",
    "@mikro-orm/core": "^6.5.9",
    "@mikro-orm/migrations": "^6.5.9",
    "@mikro-orm/nestjs": "^6.1.1",
    "@mikro-orm/reflection": "^6.5.9",
    "@mikro-orm/sqlite": "^6.5.9",
    "@nestjs/apollo": "^13.2.1",
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/cqrs": "^10.2.8",
    "@nestjs/graphql": "^13.2.0",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/testing": "^11.1.7",
    "change-case": "^5.4.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ejs": "^3.1.10",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "graphql": "^16.11.0",
    "graphql-type-json": "^0.3.2",
    "prettier": "^3.6.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.7",
    "ts-node": "^10.9.2",
    "type-fest": "^4.41.0",
    "uuid": "^11.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@auto-engineer/cli": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "version": "1.9.0"
}
