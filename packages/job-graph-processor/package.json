{
  "name": "@auto-engineer/job-graph-processor",
  "description": "Processes directed acyclic graphs of jobs with dependency tracking, parallel dispatch, and configurable failure policies",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc && tsx ../../scripts/fix-esm-imports.ts",
    "test": "vitest run --reporter=dot",
    "test:coverage": "vitest run --reporter=dot --coverage --coverage.reporter=text",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@auto-engineer/message-bus": "workspace:*",
    "@event-driven-io/emmett": "^0.38.2",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@auto-engineer/pipeline": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "version": "1.14.0"
}
