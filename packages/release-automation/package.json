{
  "name": "@auto-engineer/release-automation",
  "version": "0.26.3",
  "type": "module",
  "description": "Automated release management with changesets and conventional commits",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "release-automation": "./dist/bin/release-automation.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./lib": {
      "types": "./dist/src/lib/index.d.ts",
      "import": "./dist/src/lib/index.js"
    },
    "./cli": {
      "types": "./dist/src/cli/index.d.ts",
      "import": "./dist/src/cli/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && tsx ../../scripts/fix-esm-imports.ts && chmod +x dist/bin/release-automation.js",
    "test": "vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run integration-tests/",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "changeset",
    "release",
    "automation",
    "conventional-commits",
    "semver",
    "changelog"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "minimatch": "^10.1.1",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.3",
    "fs-extra": "^11.2.0",
    "tsx": "^4.7.1",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
