{
  "name": "@auto-engineer/pipeline",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc && tsx ../../scripts/fix-esm-imports.ts",
    "test": "vitest run --reporter=dot",
    "test:e2e": "vitest run --reporter=dot --include 'src/**/*.e2e.specs.ts'",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "e2e:kanban": "tsx scripts/run-kanban-e2e.ts",
    "serve": "tsx --watch scripts/start-server.ts"
  },
  "dependencies": {
    "@auto-engineer/message-bus": "workspace:*",
    "@auto-engineer/message-store": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.0",
    "get-port": "^7.1.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.1"
}
