{
  "name": "@auto-engineer/design-system-importer",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc && tsx ../../scripts/fix-esm-imports.ts && cp -r src/utils/templates dist/src/utils/",
    "test": "vitest run --reporter=dot",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "link:dev": "pnpm build && pnpm link --global",
    "unlink:dev": "pnpm unlink --global"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@auto-engineer/message-bus": "workspace:*",
    "figma-api": "2.0.2-beta",
    "tsx": "^3.12.7"
  },
  "devDependencies": {
    "@auto-engineer/cli": "workspace:*"
  },
  "version": "1.7.0"
}
