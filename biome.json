{
  "$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/dist",
      "!**/build",
      "!**/.next",
      "!**/coverage",
      "!**/node_modules",
      "!**/.tmp",
      "!**/generated",
      "!**/.turbo",
      "!**/package-lock.json",
      "!**/yarn.lock",
      "!**/pnpm-lock.yaml",
      "!**/.vscode",
      "!**/.idea",
      "!**/.DS_Store",
      "!**/Thumbs.db",
      "!**/.ketchup",
      "!**/.claude-auto",
      "!**/packages/frontend-generator-react-graphql/shadcn-starter",
      "!**/packages/frontend-generator-react-graphql/mui-starter",
      "!**/packages/generate-react-client/starter",
      "!**/packages/create-auto-app/templates",
      "!**/examples"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "lineEnding": "lf"
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": {
            "maxAllowedComplexity": 15
          }
        },
        "noCommaOperator": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noThenProperty": "off",
        "noTemplateCurlyInString": "off",
        "useIterableCallbackReturn": "off",
        "noAssignInExpressions": "off"
      },
      "style": {
        "noUnusedTemplateLiteral": "off",
        "useImportType": "error",
        "noNonNullAssertion": "off"
      },
      "security": {
        "noGlobalEval": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "semicolons": "always",
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "css": {
    "linter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.specs.ts", "**/*.spec.ts", "**/*.test.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": {
              "level": "warn",
              "options": {
                "maxAllowedComplexity": 15
              }
            }
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/frontend-generator-react-graphql/shadcn-starter/**",
        "packages/frontend-generator-react-graphql/mui-starter/**",
        "packages/generate-react-client/starter/**",
        "packages/create-auto-app/templates/**",
        "examples/**"
      ],
      "linter": {
        "enabled": false
      }
    }
  ]
}
