#!/bin/sh

# Check if auto-changeset is enabled
if [ "${AUTO_CHANGESET_ENABLED:-true}" = "false" ]; then
  echo "⏭️  Auto-changeset disabled (AUTO_CHANGESET_ENABLED=false)"
  exit 0
fi

# Auto-generate changesets before push
echo "🔄 Auto-generating changesets..."
pnpm tsx packages/release-automation/bin/release-automation.ts generate

# Check exit code
EXIT_CODE=$?

# Exit code 11 means no commits to process (success state)
# Exit code 12 means no conventional commits (warning but continue)
if [ $EXIT_CODE -ne 0 ] && [ $EXIT_CODE -ne 11 ] && [ $EXIT_CODE -ne 12 ]; then
  echo "❌ Failed to generate changeset (exit code: $EXIT_CODE)"
  exit $EXIT_CODE
fi

# Check if any changesets were created and amend if configured
if [ "${AUTO_CHANGESET_AMEND:-true}" = "true" ]; then
  if [ -n "$(git status --porcelain .changeset/*.md 2>/dev/null)" ]; then
    echo "📦 Staging new changesets..."
    git add .changeset/*.md

    echo "✏️  Amending commit with changesets..."
    git commit --amend --no-edit --no-verify

    echo "✅ Changesets added to commit!"
  fi
fi

# Exit successfully
exit 0
